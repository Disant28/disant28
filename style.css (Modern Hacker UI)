body {
  margin: 0;
  font-family: Arial;
  background: linear-gradient(135deg, #020617, #0f172a);
  color: white;
  text-align: center;
}

header {
  padding: 20px;
  background: #0b1220;
  box-shadow: 0 0 15px #38bdf8;
}

.container {
  margin-top: 30px;
}

input {
  width: 50%;
  padding: 12px;
  border-radius: 10px;
  border: none;
}

button {
  padding: 12px 18px;
  margin-left: 10px;
  border-radius: 10px;
  border: none;
  background: #38bdf8;
  cursor: pointer;
}

button:hover {
  background: #0ea5e9;
}

.result-box, .history, .tips {
  margin: 20px auto;
  width: 60%;
  background: rgba(255,255,255,0.05);
  padding: 20px;
  border-radius: 12px;
  backdrop-filter: blur(10px);
}
